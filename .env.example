# PostgreSQL connection string, e.g. from Neon, Supabase, Railway, or your own server.
DATABASE_URL=postgresql://user:password@host:5432/infobash

# Password organizers use to log in at /admin to view and export registrations.
ADMIN_PASSWORD=change-this-password

# Random long string used to sign the admin login session cookie.
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=change-this-to-a-random-secret
